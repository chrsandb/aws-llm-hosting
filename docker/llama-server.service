[Unit]
Description=llama.cpp Docker server
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/etc/default/llama-server
ExecStartPre=-/usr/bin/docker rm -f llama-server
ExecStart=/usr/local/bin/run-llama-server.sh
ExecStop=-/usr/bin/docker stop llama-server
Restart=always
RestartSec=10
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
