# Runtime values are templated into /etc/default/llama-server by Terraform user-data.
# This file exists as operator documentation and as a baseline for ad-hoc debugging.
LLAMA_CPP_IMAGE=ghcr.io/ggerganov/llama.cpp
LLAMA_CPP_IMAGE_TAG=server-cuda
LLAMA_ARG_MODEL=/models/UD-Q6_K_XL.gguf
LLAMA_ARG_ALIAS=qwen3.6-35b-a3b
LLAMA_ARG_CTX_SIZE=262144
LLAMA_ARG_N_PARALLEL=1
LLAMA_ARG_N_GPU_LAYERS=99
LLAMA_ARG_TEMP=0.6
LLAMA_ARG_TOP_P=0.95
LLAMA_ARG_TOP_K=20
LLAMA_ARG_MIN_P=0.00
LLAMA_ARG_THINK_BUDGET=2048
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8080
LLAMA_ARG_BATCH_SIZE=1024
LLAMA_ARG_UBATCH_SIZE=512
LLAMA_ARG_THREADS=8
LLAMA_ARG_NO_MMAP=false
LLAMA_ARG_METRICS=true
LLAMA_ARG_FLASH_ATTN=true
LLAMA_ARG_CONT_BATCHING=true
LLAMA_ARG_JINJA=enabled
